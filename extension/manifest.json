{
  "manifest_version": 3,
  "name": "HiggsBot Automation",
  "version": "0.1.0",
  "description": "Automates Higgsfield Soul image generation pipeline",
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "scripting",
    "downloads",
    "alarms"
  ],
  "host_permissions": [
    "https://higgsfield.ai/*",
    "https://www.higgsfield.ai/*",
    "https://higgsbot.vercel.app/*",
    "http://localhost:5173/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://higgsfield.ai/*", "https://www.higgsfield.ai/*"],
      "js": ["content/higgsfield-selectors.js", "content/higgsfield-automator.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://higgsbot.vercel.app/*",
        "http://localhost:5173/*"
      ],
      "js": ["content/dashboard-bridge.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
